# ── Arize Phoenix (local) ───────────────────────────────────────────────────────
# No API key needed for local Phoenix. Start the server first:
#   ./scripts/serve_phoenix.sh
ARIZE_PROJECT_NAME=shepherd
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get DSN: sentry.io → your project → Settings → Client Keys
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local default. Install: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379

# ── Browserbase ───────────────────────────────────────────────────────────────
# https://browserbase.com/dashboard
BROWSERBASE_API_KEY=bb_live_xxx

# ── Deepgram STT ──────────────────────────────────────────────────────────────
# https://console.deepgram.com
DEEPGRAM_API_KEY=xxx
# Optional tuning (defaults shown). Test endpoint: POST /api/deepgram/transcribe
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ── Overshoot screen vision ───────────────────────────────────────────────────
# https://platform.overshoot.ai/api-keys
OVERSHOOT_API_KEY=xxx

# ── Band multi-agent messaging ────────────────────────────────────────────────
# VERIFY API at event — no confirmed public Python SDK yet
BAND_API_KEY=xxx
BAND_ROOM_KEY=xxx

# ── Orkes Agentspan ───────────────────────────────────────────────────────────
# VERIFY Saturday — build ONLY if Agentspan maps cleanly to wrapping the agent run
ORKES_SERVER_URL=https://xxx.orkesconductor.com
ORKES_API_KEY=xxx

# ── Agent S (LIVE mode planner) ───────────────────────────────────────────────
# FREE LOCAL OPTION — Ollama + Qwen2.5-VL (no API key, works offline, recommended)
#   Setup: brew install ollama && ollama pull qwen2.5-vl:7b
#   Then uncomment the four lines below:
AGENT_S_ENGINE_TYPE=openai
AGENT_S_MODEL=qwen2.5-vl:7b
AGENT_S_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# PAID CLOUD OPTIONS (comment out the Ollama block above, uncomment one below):
# OpenAI:
# AGENT_S_ENGINE_TYPE=openai
# AGENT_S_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Anthropic (use Tyler's $25 credits — claude.com/offers?offer_code=fb3203ec-...):
# AGENT_S_ENGINE_TYPE=anthropic
# AGENT_S_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# Grounding model — leave empty when using Ollama (Qwen2.5-VL handles grounding too)
# Only needed for HF Inference Endpoints (UI-TARS-1.5-7B):
UITARS_BASE_URL=
UITARS_MODEL=ui-tars-1.5-7b

# macOS: also run  brew install tesseract  (required for Agent S OCR)

# Screen dimensions — match your venue display exactly
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080

# ── Engine ────────────────────────────────────────────────────────────────────
# LIVE       = Agent S per routine step (routines.json)
# LOCKED     = deterministic replay
# AUTONOMOUS = free-form goals — Agent S loops until DONE/FAIL (no routine required)
EXECUTION_MODE=LIVE
# When router finds no match in LIVE/LOCKED, fall back to autonomous (if Agent S is up)
AUTONOMOUS_ON_UNMATCHED=true
AUTONOMOUS_MAX_STEPS=30

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8765
EVENTS_DB_PATH=data/events.db

# ── Remote orchestration (coordinator relay) ──────────────────────────────────
# Set COORDINATOR_URL to turn on remote mode: the agent dials OUT to a central
# coordinator so a remote Command Center can watch its screen and steer it. Leave
# empty for purely local operation (default).
#
#   1. Run the coordinator (one public host — ngrok it or deploy it):
#        python -m coordinator           # binds 0.0.0.0:8770
#   2. Point the agent at it and start Shepherd; note the session code it prints.
#        COORDINATOR_URL=ws://localhost:8770
#   3. Point the Next.js Command Center at the same coordinator and enter the
#      session code:  NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8770
COORDINATOR_URL=
COORDINATOR_PORT=8770
# Optional shared secret enforced on all agent + UI connections.
COORDINATOR_TOKEN=
# Session join code. Leave empty to auto-generate one per run (printed on start).
AGENT_PAIRING_CODE=
# Identity shown in the Command Center (all default to the hostname).
AGENT_ID=
AGENT_NAME=
AGENT_HOST=
# Live-screen frame tuning pushed to the coordinator.
RELAY_FPS=3
RELAY_FRAME_WIDTH=1024
RELAY_FRAME_QUALITY=55
