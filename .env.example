# ── Arize Phoenix (local) ───────────────────────────────────────────────────────
# No API key needed for local Phoenix. Start the server first:
#   ./scripts/serve_phoenix.sh
ARIZE_PROJECT_NAME=shepherd
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get DSN: sentry.io → your project → Settings → Client Keys
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local default. Install: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379

# ── Browserbase ───────────────────────────────────────────────────────────────
# https://browserbase.com/dashboard
BROWSERBASE_API_KEY=bb_live_xxx

# ── Deepgram STT ──────────────────────────────────────────────────────────────
# https://console.deepgram.com
DEEPGRAM_API_KEY=xxx

# ── Overshoot screen vision ───────────────────────────────────────────────────
# https://platform.overshoot.ai/api-keys
OVERSHOOT_API_KEY=xxx

# ── Band multi-agent messaging ────────────────────────────────────────────────
# VERIFY API at event — no confirmed public Python SDK yet
BAND_API_KEY=xxx
BAND_ROOM_KEY=xxx

# ── Orkes Agentspan ───────────────────────────────────────────────────────────
# VERIFY Saturday — build ONLY if Agentspan maps cleanly to wrapping the agent run
ORKES_SERVER_URL=https://xxx.orkesconductor.com
ORKES_API_KEY=xxx

# ── Agent S (LIVE mode planner) ───────────────────────────────────────────────
# openai or anthropic. Model must support vision.
AGENT_S_ENGINE_TYPE=openai
AGENT_S_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: UI-TARS grounding endpoint (leave blank to use LLM for grounding)
# UITARS_BASE_URL=http://localhost:7860
# UITARS_MODEL=ui-tars-1.5-7b

# Screen dimensions for coordinate mapping
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080

# ── Engine ────────────────────────────────────────────────────────────────────
# LIVE = Agent S against demonstration  |  LOCKED = deterministic fallback
EXECUTION_MODE=LIVE

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8765
EVENTS_DB_PATH=data/events.db
