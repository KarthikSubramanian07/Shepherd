# ── Arize Phoenix (local) ───────────────────────────────────────────────────────
# No API key needed for local Phoenix. Start the server first:
#   ./scripts/serve_phoenix.sh
ARIZE_PROJECT_NAME=shepherd
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# Optional — leave empty to auto-resolve from Phoenix GraphQL (getProjectByName).
# PHOENIX_PROJECT_SLUG=UHJvamVjdDoy

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get DSN: sentry.io → your project → Settings → Client Keys
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Optional: tag events with an environment + enable performance tracing (0.0–1.0)
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0  # runs become Sentry transactions

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local default. Install: brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379

# ── Browserbase ───────────────────────────────────────────────────────────────
# https://browserbase.com/dashboard
BROWSERBASE_API_KEY=bb_live_xxx
BROWSERBASE_PROJECT_ID=xxx       # dashboard → Settings; required for a cloud session

# ── Deepgram STT ──────────────────────────────────────────────────────────────
# https://console.deepgram.com
DEEPGRAM_API_KEY=xxx
# Optional tuning (defaults shown). Test endpoint: POST /api/deepgram/transcribe
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US
# Voice oversight: the agent speaks the high-stakes gate question with Aura TTS and
# takes a spoken approve/stop (additive to the on-screen gate). Needs local audio.
DEEPGRAM_TTS_VOICE=aura-asteria-en
VOICE_OVERSIGHT=true

# ── Band (band.ai) multi-agent oversight ──────────────────────────────────────
# Two agents collaborate over a Band room: the engine peer posts a flagged
# high-stakes action, the shepherd-verifier peer replies with a verdict.
# 1. Register both agents at app.band.ai/agents (free Agent API tier).
# 2. Copy their UUIDs + keys into agent_config.yaml (see agent_config.yaml.example).
# 3. Create an oversight room, add both agents, and put its id below.
# The verifier process also needs ANTHROPIC_API_KEY (already set above).
BAND_ENABLED=false
BAND_ROOM_ID=xxx                 # the Band oversight room id
BAND_ENGINE_API_KEY=xxx          # the shepherd-monitor agent's Band API key
BAND_VERIFIER_AGENT_ID=xxx       # the shepherd-verifier agent's UUID (for @mention)
# Oversight COUNCIL (optional): extra specialist agents that deliberate + vote in
# the room. Register each at app.band.ai/agents, add their creds to
# agent_config.yaml (keys shepherd-security / shepherd-privacy / shepherd-destructive),
# add all three to the room, and list them here as handle:uuid pairs. Empty = the
# single shepherd-verifier acts as a council of one. Run each specialist with:
#   python -m services.band_council_agent security   (and privacy, destructive)
BAND_COUNCIL=
# e.g. BAND_COUNCIL=shepherd-security:uuid1,shepherd-privacy:uuid2,shepherd-destructive:uuid3

# ── ArmorIQ — intent-intelligence authorization ───────────────────────────────
# Secures the agent by authorizing each run's plan against an allow/deny policy
# before any action. Sign up at armoriq.ai, `pip install armoriq-sdk`,
# `armoriq login`, then grab the key (ak_live_...) from the dashboard.
ARMORIQ_ENABLED=false
ARMORIQ_API_KEY=ak_live_xxx

# ── Orkes Agentspan ───────────────────────────────────────────────────────────
# VERIFY Saturday — build ONLY if Agentspan maps cleanly to wrapping the agent run
ORKES_SERVER_URL=https://xxx.orkesconductor.com
ORKES_API_KEY=xxx

# ── Crystallization LLM (milestone segmentation + teaching loop) ──────────────
# Modular provider for the COLD-path crystallization calls (NOT the click path).
# Switch provider/model here — no code changes needed.
#   gemini    — Google Generative Language (Gemma / Gemini). Dev default.
#   anthropic — Messages API (uses LLM_ANTHROPIC_MODEL).
LLM_PROVIDER=gemini
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# gemma-4-26b-a4b-it (MoE, ~4B active — cheap/fast) | gemma-4-31b-it (dense, higher quality)
GEMINI_MODEL=gemma-4-26b-a4b-it
LLM_ANTHROPIC_MODEL=claude-haiku-4-5
# Gemma-4 always reasons before answering (~90s/call); generous budget/timeout.
LLM_TIMEOUT_S=180
LLM_MAX_TOKENS=8192

# ── Agent S (LIVE mode planner) ───────────────────────────────────────────────
# FREE LOCAL OPTION — Ollama + Qwen2.5-VL (no API key, works offline, recommended)
#   Setup: brew install ollama && ollama pull qwen2.5-vl:7b
#   Then uncomment the four lines below:
AGENT_S_ENGINE_TYPE=openai
AGENT_S_MODEL=qwen2.5-vl:7b
AGENT_S_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# PAID CLOUD OPTIONS (comment out the Ollama block above, uncomment one below):
# OpenAI:
# AGENT_S_ENGINE_TYPE=openai
# AGENT_S_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Anthropic (use Tyler's $25 credits — claude.com/offers?offer_code=fb3203ec-...):
# AGENT_S_ENGINE_TYPE=anthropic
# AGENT_S_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# Grounding model — leave empty when using Ollama (Qwen2.5-VL handles grounding too)
# Only needed for HF Inference Endpoints (UI-TARS-1.5-7B):
UITARS_BASE_URL=
UITARS_MODEL=ui-tars-1.5-7b

# macOS: also run  brew install tesseract  (required for Agent S OCR)

# Screen dimensions — match your venue display exactly
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1080

# ── Engine ────────────────────────────────────────────────────────────────────
# Front door for every intent. These knobs are DEFAULTED IN config.py — the
# committed defaults are: USE_ROUTER=true, MATCH_WORKFLOWS=true, MATCH_ROUTINES=false
# (route to crystallized workflows only, then autonomous fallback). Uncomment a
# line below ONLY to override config.py for this machine.
#   USE_ROUTER=false — skip routing; run every intent as a free-form autonomous
#       Agent S goal. true — match first; autonomous fallback (AUTONOMOUS_ON_UNMATCHED).
#   ROUTINE_REPLAY=vision|deterministic — how a matched routine is driven
#       (vision = Agent S per step; deterministic = replay recorded coordinates).
#   MATCH_WORKFLOWS / MATCH_ROUTINES — enable each routing SOURCE independently
#       (when USE_ROUTER=true). Both false = router always falls back to autonomous.
# USE_ROUTER=true
ROUTINE_REPLAY=vision
# MATCH_WORKFLOWS=true
# MATCH_ROUTINES=false
# Legacy override: an explicit LIVE/LOCKED/AUTONOMOUS here WINS over USE_ROUTER.
# Leave it OUT unless you specifically need to pin the old enum — setting it (e.g.
# EXECUTION_MODE=LIVE) silently forces routing and ignores USE_ROUTER.
# EXECUTION_MODE=
# When USE_ROUTER and the router finds no match, fall back to autonomous (if Agent S is up)
AUTONOMOUS_ON_UNMATCHED=true
AUTONOMOUS_MAX_STEPS=20
# Feed this goal's prior milestone graph into the planner. Off by default — each
# run plans fresh; turn on to recall a goal's accumulated milestones.
AUTONOMOUS_USE_MEMORY=false
# Chain several UI actions per screenshot. Must fit a full field replace
# (activate + click + select-all + type + confirm) or the model loops re-selecting.
AUTONOMOUS_CHAIN=true
AUTONOMOUS_CHAIN_MAX=5
# Draft a plan first, then run the reactive Agent S loop with it as a roadmap
AUTONOMOUS_PLAN_FIRST=true
AUTONOMOUS_PLAN_MAX_STEPS=12
# Routine planner — text-only step drafting (independent of Agent S vision model)
PLANNER_ENGINE_TYPE=anthropic
PLANNER_MODEL=claude-haiku-4-5

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8765
EVENTS_DB_PATH=data/events.db

# ── Remote orchestration (coordinator relay) ──────────────────────────────────
# Set COORDINATOR_URL to turn on remote mode: the agent dials OUT to a central
# coordinator so a remote Command Center can watch its screen and steer it. Leave
# empty for purely local operation (default).
#
#   1. Run the coordinator (one public host — ngrok it or deploy it):
#        python -m coordinator           # binds 0.0.0.0:8770
#   2. Point the agent at it and start Shepherd; note the session code it prints.
#        COORDINATOR_URL=ws://localhost:8770
#   3. Point the Next.js Command Center at the same coordinator and enter the
#      session code:  NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8770
COORDINATOR_URL=
COORDINATOR_PORT=8770
# Optional shared secret enforced on all agent + UI connections.
COORDINATOR_TOKEN=
# Session join code. Leave empty to auto-generate one per run (printed on start).
AGENT_PAIRING_CODE=
# Identity shown in the Command Center (all default to the hostname).
AGENT_ID=
AGENT_NAME=
AGENT_HOST=
# Live-screen frame tuning pushed to the coordinator.
RELAY_FPS=3
RELAY_FRAME_WIDTH=1024
RELAY_FRAME_QUALITY=55

# Agentspan (Orkes) durable agent engine. Open-source, keyless locally.
# Run: agentspan server start  (the research agent reuses ANTHROPIC_API_KEY).
AGENTSPAN_SERVER_URL=http://localhost:6767/api
