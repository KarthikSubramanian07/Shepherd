# ── Local backend proxy ───────────────────────────────────────────────────────
# Where the Next.js server-side routes proxy to (e.g. /api/deepgram/*). Point at
# the agent's dashboard locally, or at the coordinator when running remote so the
# Command Center can transcribe voice without its own backend.
SHEPHERD_API_BASE=http://localhost:8765

# ── Remote Command Center (coordinator relay) ─────────────────────────────────
# The coordinator the Remote Command Center (/remote) connects to. Use the
# coordinator's public URL (e.g. an ngrok https URL) when driving remote agents.
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8770
# Optional shared secret if the coordinator enforces COORDINATOR_TOKEN.
NEXT_PUBLIC_COORDINATOR_TOKEN=
