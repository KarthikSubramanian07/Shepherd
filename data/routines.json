[
  {
    "routine_id": "ROUTINE_FORM_FILL",
    "description": "Fill a WorkBridge job application form. Monitor halts at the credential field \u2014 the planted demo trigger.",
    "variables": [
      "APPLICANT_NAME",
      "APPLICANT_LASTNAME",
      "APPLICANT_EMAIL",
      "APPLICANT_PHONE"
    ],
    "mode": "LIVE",
    "high_stakes_steps": [
      4
    ],
    "step_instructions": {
      "0": "Open the WorkBridge candidate portal in Safari",
      "5": "The first name field is auto-focused after page load",
      "17": "PLANTED TRIGGER: tab to password / API key field \u2014 monitor halts every time"
    },
    "steps": [
      {
        "action": "open_app",
        "target": "Google Chrome",
        "description": "Open browser",
        "text": "http://localhost:8765/demo-form"
      },
      {
        "action": "wait",
        "seconds": 2.0,
        "description": "Wait for browser"
      },
      {
        "action": "wait",
        "seconds": 1.5,
        "description": "Wait for form"
      },
      {
        "action": "batch_fill",
        "description": "Fill applicant form fields",
        "fields": [
          {
            "tabs": 1,
            "text": "{APPLICANT_NAME}",
            "description": "First name"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_LASTNAME}",
            "description": "Last name"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_EMAIL}",
            "description": "Email"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_PHONE}",
            "description": "Phone"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_LINKEDIN}",
            "description": "LinkedIn"
          },
          {
            "tabs": 1,
            "description": "Skip role select (keep default)"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_EXPERIENCE}",
            "description": "Years of experience"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_SALARY}",
            "description": "Expected salary"
          }
        ]
      },
      {
        "action": "hotkey",
        "keys": [
          "tab"
        ],
        "description": "Tab to password / API key \u2014 MONITOR TRIGGER",
        "monitor_trigger": "credential"
      },
      {
        "action": "hotkey",
        "keys": [
          "cmd",
          "return"
        ],
        "description": "Submit form"
      }
    ],
    "demonstration": null
  },
  {
    "routine_id": "ROUTINE_BROWSER_SHOWPIECE",
    "description": "Open a Browserbase cloud browser session and navigate to a URL. Falls back to local stub if offline.",
    "variables": [
      "SEARCH_QUERY"
    ],
    "mode": "LIVE",
    "high_stakes_steps": [],
    "step_instructions": {
      "0": "Uses Browserbase \u2014 a real remote browser, not a local tab"
    },
    "steps": [
      {
        "action": "browser",
        "description": "Open Browserbase cloud browser",
        "browser_step": {
          "url": "https://www.google.com",
          "action": "navigate"
        }
      },
      {
        "action": "wait",
        "seconds": 1.5,
        "description": "Wait for page load"
      }
    ],
    "demonstration": null
  },
  {
    "routine_id": "ROUTINE_LOCKED_FALLBACK",
    "description": "Deterministic offline fallback \u2014 opens TextEdit and types a note. Used if live agent flakes during demo.",
    "variables": [
      "NOTE_TEXT"
    ],
    "mode": "LOCKED",
    "high_stakes_steps": [],
    "step_instructions": {},
    "steps": [
      {
        "action": "open_app",
        "target": "TextEdit",
        "description": "Open TextEdit"
      },
      {
        "action": "wait",
        "seconds": 2.0,
        "description": "Wait for app"
      },
      {
        "action": "hotkey",
        "keys": [
          "cmd",
          "n"
        ],
        "description": "New document"
      },
      {
        "action": "wait",
        "seconds": 0.5
      },
      {
        "action": "type",
        "text": "Shepherd Demo Run\n",
        "description": "Type header"
      },
      {
        "action": "type",
        "text": "{NOTE_TEXT}\n",
        "description": "Type note"
      },
      {
        "action": "hotkey",
        "keys": [
          "cmd",
          "s"
        ],
        "description": "Save"
      },
      {
        "action": "wait",
        "seconds": 0.5
      },
      {
        "action": "hotkey",
        "keys": [
          "escape"
        ],
        "description": "Dismiss dialog"
      }
    ],
    "demonstration": null
  }
]