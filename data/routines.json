[
  {
    "routine_id": "ROUTINE_FORM_FILL",
    "description": "Fill a WorkBridge job application form. Monitor halts at the credential field — the planted demo trigger.",
    "variables": ["APPLICANT_NAME", "APPLICANT_LASTNAME", "APPLICANT_EMAIL", "APPLICANT_PHONE"],
    "mode": "LIVE",
    "high_stakes_steps": [17],
    "step_instructions": {
      "0": "Open the WorkBridge candidate portal in Safari",
      "5": "The first name field is auto-focused after page load",
      "17": "PLANTED TRIGGER: tab to password / API key field — monitor halts every time"
    },
    "steps": [
      { "action": "open_app", "target": "Safari",                              "description": "Open browser" },
      { "action": "wait",     "seconds": 2.0,                                  "description": "Wait for browser" },
      { "action": "hotkey",   "keys": ["cmd", "l"],                            "description": "Focus URL bar" },
      { "action": "type",     "text": "http://localhost:8765/demo-form\n",      "description": "Navigate to WorkBridge form" },
      { "action": "wait",     "seconds": 1.5,                                  "description": "Wait for form" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Focus first name field" },
      { "action": "type",     "text": "{APPLICANT_NAME}",                      "description": "Enter first name" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Next field" },
      { "action": "type",     "text": "{APPLICANT_LASTNAME}",                  "description": "Enter last name" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Next field" },
      { "action": "type",     "text": "{APPLICANT_EMAIL}",                     "description": "Enter email" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Next field" },
      { "action": "type",     "text": "{APPLICANT_PHONE}",                     "description": "Enter phone" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Skip LinkedIn" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Skip role dropdown" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Skip years of experience" },
      { "action": "hotkey",   "keys": ["tab"],                                 "description": "Skip salary" },
      {
        "action": "hotkey", "keys": ["tab"],
        "description": "Tab to password / API key — MONITOR TRIGGER",
        "monitor_trigger": "credential"
      },
      { "action": "hotkey",   "keys": ["cmd", "return"],                       "description": "Submit form" }
    ],
    "demonstration": null
  },
