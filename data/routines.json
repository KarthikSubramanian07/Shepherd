    "high_stakes_steps": [],
    "step_instructions": {
      "0": "Open the WorkBridge candidate portal in Google Chrome",
      "3": "Research the applicant's GitHub on the live web before filling Projects",
      "4": "Fill the Projects field with the summary read from GitHub"
    },
    "steps": [
      {
        "action": "open_app",
        "target": "Google Chrome",
        "description": "Open application form",
        "text": "http://localhost:8765/demo-form"
      },
      {
        "action": "wait",
        "seconds": 2.0,
        "description": "Wait for browser"
      },
      {
        "action": "wait",
        "seconds": 1.5,
        "description": "Wait for form"
      },
      {
        "action": "batch_fill",
        "description": "Fill known details",
        "fields": [
          {
            "tabs": 1,
            "text": "{APPLICANT_NAME}",
            "description": "First name",
            "html_name": "fname"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_LASTNAME}",
            "description": "Last name",
            "html_name": "lname"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_EMAIL}",
            "description": "Email",
            "html_name": "email"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_PHONE}",
            "description": "Phone",
            "html_name": "phone"
          }
        ]
      },
      {
        "action": "browser",
        "description": "Research GitHub projects",
        "browser_step": {
          "action": "read",
          "url": "https://github.com/{GITHUB_USER}",
          "store_as": "PROJECTS_SUMMARY",
          "fallback_value": "Notable work: an open-source automation CLI, a real-time data pipeline, and a governance dashboard for AI agents.",
          "agent_research": true
