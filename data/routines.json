[
  {
    "routine_id": "ROUTINE_FORM_FILL",
    "description": "Fill a WorkBridge job application form. Monitor halts at the credential field \u2014 the planted demo trigger.",
    "variables": [
      "APPLICANT_NAME",
      "APPLICANT_LASTNAME",
      "APPLICANT_EMAIL",
      "APPLICANT_PHONE"
    ],
    "mode": "LIVE",
    "high_stakes_steps": [
      6
    ],
    "step_instructions": {
      "0": "Open the WorkBridge candidate portal in Safari",
      "5": "The first name field is auto-focused after page load",
      "17": "PLANTED TRIGGER: tab to password / API key field \u2014 monitor halts every time"
    },
    "steps": [
      {
        "action": "open_app",
        "target": "Google Chrome",
        "description": "Open browser",
        "text": "http://localhost:8765/demo-form"
      },
      {
        "action": "wait",
        "seconds": 2.0,
        "description": "Wait for browser"
      },
      {
        "action": "wait",
        "seconds": 0.5,
        "description": "Page settling"
      },
      {
        "action": "wait",
        "seconds": 0.5,
        "description": "Page settling"
      },
      {
        "action": "wait",
        "seconds": 1.5,
        "description": "Wait for form"
      },
      {
        "action": "batch_fill",
        "description": "Fill applicant form fields",
        "fields": [
          {
            "tabs": 1,
            "text": "{APPLICANT_NAME}",
            "description": "First name"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_LASTNAME}",
            "description": "Last name"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_EMAIL}",
            "description": "Email"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_PHONE}",
            "description": "Phone"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_EXPERIENCE}",
            "description": "Years of experience"
          },
          {
            "tabs": 1,
            "text": "{APPLICANT_SALARY}",
            "description": "Expected salary"
          },
          {
            "tabs": 4,
            "description": "Skip past portfolio to password section"
          }
        ]
      },
      {
        "action": "hotkey",
        "keys": [
          "tab"
        ],
        "description": "Tab to password / API key \u2014 MONITOR TRIGGER",
        "monitor_trigger": "credential"
      },
      {
        "action": "hotkey",
        "keys": [
          "cmd",
          "return"
        ],
        "description": "Submit form"
      }
    ],
    "demonstration": null
  },
