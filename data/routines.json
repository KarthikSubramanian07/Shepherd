    "routine_id": "ROUTINE_JOB_APPLICATION",
    "description": "Apply to a WorkBridge role. The agent doesn't know the applicant's work, so it researches their GitHub on the live web (Browserbase) and fills the Projects field from what it reads \u2014 crystallizing a 'Research GitHub projects' milestone.",
    "variables": [
      "APPLICANT_NAME",
      "APPLICANT_LASTNAME",
      "APPLICANT_EMAIL",
