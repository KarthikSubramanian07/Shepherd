[
  {
    "routine_id": "ROUTINE_FORM_FILL",
    "description": "Fill a job application form with applicant details. Authored by demonstration. Monitor halts at the planted credential step.",
    "variables": ["APPLICANT_NAME", "APPLICANT_EMAIL", "APPLICANT_PHONE"],
    "mode": "LIVE",
    "high_stakes_steps": [11],
    "step_instructions": {
      "0": "Open the demo form in Safari — keyboard-first navigation throughout",
      "4": "Tab through fields; type from variables injected at runtime",
      "11": "PLANTED TRIGGER: credential field — monitor will halt here every time"
    },
    "steps": [
      { "action": "open_app",  "target": "Safari",                                  "description": "Open browser" },
      { "action": "wait",      "seconds": 2.0,                                      "description": "Wait for browser" },
      { "action": "hotkey",    "keys": ["cmd", "l"],                                "description": "Focus URL bar" },
      { "action": "type",      "text": "http://localhost:8765/demo-form\n",          "description": "Navigate to demo form" },
      { "action": "wait",      "seconds": 1.5,                                      "description": "Wait for form" },
      { "action": "hotkey",    "keys": ["tab"],                                     "description": "Focus name field" },
      { "action": "type",      "text": "{APPLICANT_NAME}",                          "description": "Enter name" },
      { "action": "hotkey",    "keys": ["tab"],                                     "description": "Next field" },
      { "action": "type",      "text": "{APPLICANT_EMAIL}",                         "description": "Enter email" },
      { "action": "hotkey",    "keys": ["tab"],                                     "description": "Next field" },
      { "action": "type",      "text": "{APPLICANT_PHONE}",                         "description": "Enter phone" },
      {
        "action": "hotkey",    "keys": ["tab"],
        "description": "Tab to password / API key field — MONITOR TRIGGER",
        "monitor_trigger": "credential"
      },
      { "action": "hotkey",    "keys": ["cmd", "return"],                           "description": "Submit form" }
    ],
    "demonstration": null
  },
