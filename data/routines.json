          {
            "tabs": 1,
            "text": "{PROJECTS_SUMMARY}",
            "description": "Projects",
            "html_name": "projects"
          }
        ]
      },
      {
        "action": "hotkey",
        "keys": [
          "cmd",
          "return"
        ],
        "description": "Submit application"
      }
